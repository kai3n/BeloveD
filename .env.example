DATABASE_URL=postgres://localhost:5432/belovediamond
API_PORT=8787
# Standalone dev API defaults to loopback. Set explicitly only when LAN access
# is intentional; production defaults to 0.0.0.0.
API_HOST=127.0.0.1

# R2-unconfigured development fallback only. Completed files are reloaded after
# restart, retained for 24h, and pending+stored bytes are capped at 512 MiB.
LOCAL_MEDIA_RETENTION_MS=86400000
LOCAL_MEDIA_MAX_BYTES=536870912
# LOCAL_MEDIA_ROOT=/absolute/path/to/dev-media

# Canonical public origin used to build magic-link URLs and to validate the
# Origin header on state-changing requests. REQUIRED in production; the server
# refuses to mint magic links without it. Never derived from the request Host.
# Must exactly match the browser origin used by Vite in development.
PUBLIC_ORIGIN=http://127.0.0.1:5173
# White-label Vendor App origin. It may be a separate domain; the API allows
# credentialed CORS only for this exact origin.
VENDOR_ORIGIN=http://127.0.0.1:5174

# China-friendly vendor uploads: Tencent COS (bucket must include APPID).
# Keep these credentials on the API server only. The browser receives a
# short-lived PUT URL and never receives SecretId/SecretKey.
VENDOR_MEDIA_PROVIDER=cos
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_ACCESS_KEY_ID=
COS_SECRET_ACCESS_KEY=
# Optional; this default is derived from COS_REGION when blank.
COS_ENDPOINT=
# Public/custom media domain without a trailing slash.
COS_PUBLIC_URL=

# Unsafe demo authentication helpers are opt-in and should stay false normally.
VITE_ENABLE_DEMO_AUTH=false
VITE_DEMO_AUTH_PASSWORD=
# Local automation only. Never enable on a shared or production deployment.
EXPOSE_DEV_AUTH_SECRETS=false

# Admin seed credentials (used by `npm run seed:admin`).
# In production SEED_ADMIN_PASSWORD is mandatory (min 10 chars) — seeding aborts
# without it. In dev, leaving it unset generates a random password.
SEED_ADMIN_EMAIL=admin@belovediamond.test
SEED_ADMIN_PASSWORD=

# Postgres TLS. In production the pool requires TLS (rejectUnauthorized: true).
# Set PGSSL=disable to opt out (e.g. a trusted local/socket connection).
PGSSL=

PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000

# Email delivery via Resend. Unset = dev sink (codes/links logged in dev only).
RESEND_API_KEY=
# Sender identity. Before domain verification use onboarding@resend.dev;
# after verifying belovediamond.com switch to no-reply@belovediamond.com.
MAIL_FROM=

# Local convention: real project secrets live in .env.beloved (gitignored).
